#!/usr/bin/env bash

set -euo pipefail

die() { echo "$@" >&2; exit 1; }

main() {
  [[ $# -eq 1 && $1 == https://* ]] ||
    die "curl+ takes one arg which must be a url"

  local url=$1
  local name=${url#https://}
  name=${name//\//__}

  local target
  target=$(mktemp)
  # shellcheck disable=SC2064  # expand $target now: it's local to main()
  trap "rm -f '$target'" EXIT

  local makes_cache=${BASH_SOURCE[0]%/*}/makes-cache

  # Retry in the shell: curl's --retry misses some transient errors
  # (HTTP/2 stream resets) and --retry-all-errors needs curl 7.71+,
  # newer than ubuntu:20.04 build containers have.
  local try
  for try in 1 2 3 4 5; do
    if MAKES_CACHE_NAME=$name \
       MAKES_CACHE_DEPS=_ \
       "$makes_cache" "$target" \
         curl -fsSL -o "$target" "$url"; then
      cat "$target"
      return 0
    fi
    if [[ $try -lt 5 ]]; then
      echo "curl+ failed to fetch '$url' (try $try of 5); retrying" >&2
      sleep 3
    fi
  done

  die "curl+ failed to fetch '$url' after 5 tries"
}

main "$@"
